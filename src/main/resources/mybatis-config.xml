<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE configuration
        PUBLIC "-//mybatis.org//DTD Config 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-config.dtd">
<configuration>
    <!-- 全局设置，开启驼峰命名自动映射（order_id -> orderId） -->
    <settings>
        <setting name="mapUnderscoreToCamelCase" value="true"/>
        <setting name="logImpl" value="STDOUT_LOGGING"/> <!-- 控制台打印SQL，方便调试 -->
    </settings>
    <!-- 给实体类起别名，简化SQL里的类型书写 -->
    <typeAliases>
        <package name="com.flower.entity"/>
    </typeAliases>
</configuration>
